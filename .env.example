# Example environment variables for CampusEats backend

# Cryptographically strong random string in production
SECRET_KEY=change_me_in_production

# Token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database URL
# For local dev (SQLite):
DATABASE_URL=sqlite:///./campus_eats.db
# For production (PostgreSQL example):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/campuseats

# CORS origins: comma-separated list of frontend URLs
# Example: http://localhost:5173,https://campuseats.app
CORS_ORIGINS=*

